+  /// Backwards-compatibility aliases for tim2tox callers written against the
+  /// 8.7.x API surface (renamed to `addTimXxx2Map` in 8.9.x). These delegate
+  /// to the new names with the same signatures, so dart/lib code in
+  /// third_party/tim2tox does not need a coordinated rename.
+  static void timCallback2Future(
+          String userData, Completer<V2TimCallback> completer) =>
+      addTimCallback2Map(userData, completer);
+  static void timValueCallback2Future<T>(
+          String userData, Completer<V2TimValueCallback<T>> completer) =>
+      addTimValueCallback2Map<T>(userData, completer);
+  static void timApiValueCallback2Future(
+          String userData, ApiCallback callback) =>
+      addTimApiValueCallback2Map(userData, callback);
+
+  /// 从全局回调数据中获取指定 key 的字符串值。
+  ///
+  /// tim2tox's callback bridge may deliver the value as a String, an
+  /// already-decoded List/Map, or null. Normalize all three to a JSON
+  /// string so callers' `json.decode(rawValue)` continues to work.
+  static String _getGlobalCallbackJsonString(
+      Map<String, dynamic> dataFromNativeMap, String key) {
+    final raw = dataFromNativeMap[key];
+    if (raw == null) return '';
+    if (raw is String) return raw;
+    if (raw is List || raw is Map) return json.encode(raw);
+    return raw.toString();
   }
 
   static void _handleGlobalCallback(Map<String, dynamic> dataFromNativeMap) {
     int callbackType = dataFromNativeMap["callbackType"];
-    GlobalCallbackType globalCallbackType = GlobalCallbackType.fromValue(callbackType);
+    // Tim2tox multi-instance routing: when the native side stamps an
+    // `instance_id` onto the callback, fan out to per-instance listeners via
+    // the typed dispatchInstanceGlobalCallback extension point on the
+    // platform interface (default no-op; Tim2ToxSdkPlatform overrides).
+    final rawId = dataFromNativeMap["instance_id"];
+    final int? instanceId = rawId == null
+        ? null
+        : (rawId is int
+            ? rawId
+            : (rawId is num
+                ? rawId.toInt()
+                : int.tryParse(rawId.toString())));
+    final platform = TencentCloudChatSdkPlatform.instance;
+    if (instanceId != null && platform.isCustomPlatform) {
+      platform.dispatchInstanceGlobalCallback(
+          instanceId, callbackType, dataFromNativeMap);
+      // For non-zero instance, only fall through for FriendAddRequest so
+      // _friendshipListener is also called (matches 8.7 tim2tox behavior).
+      if (instanceId != 0 &&
+          callbackType != GlobalCallbackType.FriendAddRequest.value) {
+        return;
+      }
+    }
+    final GlobalCallbackType globalCallbackType;
+    try {
+      globalCallbackType = GlobalCallbackType.fromValue(callbackType);
+    } on ArgumentError {
+      return;
+    }
     switch (globalCallbackType) {
       case GlobalCallbackType.NetworkStatus: {
         int code = dataFromNativeMap["code"];
