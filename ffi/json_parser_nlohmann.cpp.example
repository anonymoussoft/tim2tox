// Example: Using nlohmann/json to replace manual JSON parsing
// This file demonstrates how to migrate from manual parsing to nlohmann/json

#include "json_parser.h"
#include <nlohmann/json.hpp>
#include <sstream>

using json = nlohmann::json;

// Improved ParseJsonString using nlohmann/json
std::map<std::string, std::string> ParseJsonString(const std::string& json_str) {
    std::map<std::string, std::string> result;
    
    try {
        json j = json::parse(json_str);
        
        // Convert JSON object to flat map
        // Handle nested objects by flattening keys (e.g., "obj.key" -> "obj_key")
        if (j.is_object()) {
            for (auto& [key, value] : j.items()) {
                if (value.is_string()) {
                    result[key] = value.get<std::string>();
                } else if (value.is_number()) {
                    result[key] = std::to_string(value.get<double>());
                } else if (value.is_boolean()) {
                    result[key] = value.get<bool>() ? "true" : "false";
                } else if (value.is_null()) {
                    result[key] = "";
                } else if (value.is_object() || value.is_array()) {
                    // For nested objects/arrays, serialize to JSON string
                    result[key] = value.dump();
                }
            }
        }
    } catch (const json::parse_error& e) {
        V2TIM_LOG(kError, "[json_parser] ParseJsonString failed: {}", e.what());
        // Fallback to empty map
    } catch (const std::exception& e) {
        V2TIM_LOG(kError, "[json_parser] ParseJsonString exception: {}", e.what());
    }
    
    return result;
}

// Improved ExtractJsonValue using nlohmann/json
std::string ExtractJsonValue(const std::string& json_str, const std::string& key, bool silent) {
    try {
        json j = json::parse(json_str);
        
        if (j.contains(key)) {
            auto& value = j[key];
            if (value.is_string()) {
                return value.get<std::string>();
            } else if (value.is_number()) {
                return std::to_string(value.get<double>());
            } else if (value.is_boolean()) {
                return value.get<bool>() ? "true" : "false";
            } else if (value.is_null()) {
                return "";
            } else {
                // For objects/arrays, return JSON string
                return value.dump();
            }
        }
    } catch (const json::parse_error& e) {
        if (!silent) {
            V2TIM_LOG(kError, "[json_parser] ExtractJsonValue parse error for key '{}': {}", key, e.what());
        }
    } catch (const std::exception& e) {
        if (!silent) {
            V2TIM_LOG(kError, "[json_parser] ExtractJsonValue exception for key '{}': {}", key, e.what());
        }
    }
    
    return "";
}

// Improved ExtractJsonInt
int ExtractJsonInt(const std::string& json_str, const std::string& key, int default_value, bool silent) {
    try {
        json j = json::parse(json_str);
        
        if (j.contains(key) && j[key].is_number()) {
            return j[key].get<int>();
        }
    } catch (const std::exception& e) {
        if (!silent) {
            V2TIM_LOG(kError, "[json_parser] ExtractJsonInt exception: {}", e.what());
        }
    }
    
    return default_value;
}

// Improved ExtractJsonBool
bool ExtractJsonBool(const std::string& json_str, const std::string& key, bool default_value) {
    try {
        json j = json::parse(json_str);
        
        if (j.contains(key) && j[key].is_boolean()) {
            return j[key].get<bool>();
        }
    } catch (const std::exception& e) {
        V2TIM_LOG(kError, "[json_parser] ExtractJsonBool exception: {}", e.what());
    }
    
    return default_value;
}

// Parse JSON array of strings
std::vector<std::string> ParseJsonStringArray(const std::string& json_str) {
    std::vector<std::string> result;
    
    try {
        json j = json::parse(json_str);
        
        if (j.is_array()) {
            for (auto& item : j) {
                if (item.is_string()) {
                    result.push_back(item.get<std::string>());
                }
            }
        }
    } catch (const std::exception& e) {
        V2TIM_LOG(kError, "[json_parser] ParseJsonStringArray exception: {}", e.what());
    }
    
    return result;
}

// Improved BuildJsonObject using nlohmann/json
std::string BuildJsonObject(const std::map<std::string, std::string>& fields) {
    json j;
    
    for (const auto& [key, value] : fields) {
        // Try to parse value as JSON (for nested objects/arrays)
        try {
            json parsed_value = json::parse(value);
            j[key] = parsed_value;
        } catch (...) {
            // If parsing fails, treat as string
            j[key] = value;
        }
    }
    
    return j.dump();
}

// Improved EscapeJsonString (nlohmann/json handles this automatically, but keep for compatibility)
std::string EscapeJsonString(const std::string& str) {
    // nlohmann/json handles escaping automatically in dump()
    // This function is kept for backward compatibility
    json j = str;
    std::string escaped = j.dump();
    // Remove surrounding quotes added by dump() for strings
    if (escaped.length() >= 2 && escaped[0] == '"' && escaped[escaped.length()-1] == '"') {
        return escaped.substr(1, escaped.length() - 2);
    }
    return escaped;
}
